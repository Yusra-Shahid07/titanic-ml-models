adata":{}},{"cell_type":"code","source":"def sigmoid(num):\n    return 1/(1+np.exp(-num))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T22:11:18.073675Z","iopub.execute_input":"2026-07-17T22:11:18.073924Z","iopub.status.idle":"2026-07-17T22:11:18.091661Z","shell.execute_reply.started":"2026-07-17T22:11:18.073902Z","shell.execute_reply":"2026-07-17T22:11:18.090757Z"}},"outputs":[],"execution_count":103},{"cell_type":"markdown","source":"## 3. Variable Intialization","metadata":{}},{"cell_type":"code","source":"m = np.zeros(3)\nb=0\nlearning_rate=0.1 #gradient chota kiya tu ab learning rate increase kiya tha kae update aur chota na hojae\nn = len(X_scratch)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T22:11:18.092522Z","iopub.execute_input":"2026-07-17T22:11:18.092749Z","iopub.status.idle":"2026-07-17T22:11:18.111485Z","shell.execute_reply.started":"2026-07-17T22:11:18.092727Z","shell.execute_reply":"2026-07-17T22:11:18.1109Z"}},"outputs":[],"execution_count":104},{"cell_type":"markdown","source":"## 4.Cost Function","metadata":{}},{"cell_type":"code","source":"def cost(X_scratch,y_scratch,m,b):\n    predictions_scratch=sigmoid(X_scratch @ m+b)\n    epsilon = 1e-15\n    predictions_scratch = np.clip(predictions_scratch, epsilon, 1 - epsilon)#log 0=-inf  tu 0 ya 1 ni hona chayey aghr \n    #epsilon sae chota tu =epsilon kardeta aghr epsilon sae big value tu 1-epsilon kae equal kardeta hai \n    loss = -y_scratch*np.log(predictions_scratch) - (1-y_scratch)*np.log(1-predictions_scratch)  \n    return np.mean(loss)  #loss main mul values haar row ka loss #np.mean(loss) = np.sum(loss) / n \n#means loss J = (1/n) * Σ [-y*log(p) - (1-y)*log(1-p)]\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T22:11:18.112244Z","iopub.execute_input":"2026-07-17T22:11:18.112449Z","iopub.status.idle":"2026-07-17T22:11:18.132886Z","shell.execute_reply.started":"2026-07-17T22:11:18.112429Z","shell.execute_reply":"2026-07-17T22:11:18.131929Z"}},"outputs":[],"execution_count":105},{"cell_type":"markdown","source":"## 5. Gradient Function","metadata":{}},{"cell_type":"code","source":"def grad(X_scratch,y_scratch,m,b,learning_rate):\n    predictions_scratch=sigmoid(X_scratch @ m+b)\n    dm = (1/n) * X_scratch.T @ (predictions_scratch - y_scratch)\n    db = (1/n) * np.sum(predictions_scratch - y_scratch)\n    m=m-learning_rate*dm\n    b=b-learning_rate*db\n    return m,b","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T22:11:18.133706Z","iopub.execute_input":"2026-07-17T22:11:18.133972Z","iopub.status.idle":"2026-07-17T22:11:18.153976Z","shell.execute_reply.started":"2026-07-17T22:11:18.133953Z","shell.execute_reply":"2026-07-17T22:11:18.15321Z"}},"outputs":[],"execution_count":106},{"cell_type":"markdown","source":"## 6. Training Model","metadata":{}},{"cell_type":"code","source":"for i in range(1000):\n    m, b = grad(X_scratch, y_scratch, m, b, learning_rate)\n    if i % 100 == 0:\n        print(f\"i={i}, m={m}, b={b:.4f}, loss={cost(X_scratch, y_scratch, m, b)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-17T22:11:18.156297Z","iopub.execute_input":"2026-07-17T22:11:18.15656Z","iopub.status.idle":"2026-07-17T22:11:18.207643Z","shell.execute_reply.started":"2026-07-17T22:11:18.156537Z","shell.execute_reply":"2026-07-17T22:11:18.206731Z"}},"outputs":[{"name":"stdout","text":"i=0, m=[-0.01646099  0.01251331  0.02642423], b=-0.0116, loss=0.6807552259988503\ni=100, m=[-0.52030036  0.23081813  1.00806478], b=-0.4759, loss=0.471461762946067\ni=200, m=[-0.64260214  0.17382901  1.17791635], b=-0.5744, loss=0.4651564571349749\ni=300, m=[-0.70305775  0.12749334  1.22519993], b=-0.6073, loss=0.4641995491126951\ni=400, m=[-0.73418619  0.10072147  1.24233613], b=-0.6200, loss=0.4639772616753679\ni=500, m=[-0.75009922  0.08659731  1.24973939], b=-0.6255, loss=0.46392154973429733\ni=600, m=[-0.75817265  0.07937558  1.25324713], b=-0.6281, los