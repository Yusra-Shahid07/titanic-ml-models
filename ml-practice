ll_type":"code","source":"m = np.zeros(3)\nb=0\nlearning_rate=0.1 #gradient chota kiya tu ab learning rate increase kiya tha kae update aur chota na hojae\nn = len(X_scratch)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 4.Cost Function","metadata":{}},{"cell_type":"code","source":"def cost(X_scratch,y_scratch,m,b):\n    predictions_scratch=sigmoid(X_scratch @ m+b)\n    epsilon = 1e-15\n    predictions_scratch = np.clip(predictions_scratch, epsilon, 1 - epsilon)#log 0=-inf  tu 0 ya 1 ni hona chayey aghr \n    #epsilon sae chota tu =epsilon kardeta aghr epsilon sae big value tu 1-epsilon kae equal kardeta hai \n    loss = -y_scratch*np.log(predictions_scratch) - (1-y_scratch)*np.log(1-predictions_scratch)  \n    return np.mean(loss)  #loss main mul values haar row ka loss #np.mean(loss) = np.sum(loss) / n \n#means loss J = (1/n) * Σ [-y*log(p) - (1-y)*log(1-p)]\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 5. Gradient Function","metadata":{}},{"cell_type":"code","source":"def grad(X_scratch,y_scratch,m,b,learning_rate):\n    predictions_scratch=sigmoid(X_scratch @ m+b)\n    dm = (1/n) * X_scratch.T @ (predictions_scratch - y_scratch)\n    db = (1/n) * np.sum(predictions_scratch - y_scratch)\n    m=m-learning_rate*dm\n    b=b-learning_rate*db\n    return m,b","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 6. Training Model","metadata":{}},{"cell_type":"code","source":"for i in range(1000):\n    m, b = grad(X_scratch, y_scratch, m, b, learning_rate)\n    if i % 100 == 0:\n        print(f\"i={i}, m={m}, b={b:.4f}, loss={cost(X_scratch, y_scratch, m, b)}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 7.Testing Model","metadata":{}},{"cell_type":"code","source":"X_testscratch=scaler.transform(test_data[features].values)\npredictions_testscratch=sigmoid(X_testscratch @ m+b)\nfinal_predictions = (predictions_testscratch >= 0.5).astype(int)\nprint(final_predictions)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 8. Model Evaluation\n### 8.1 Train/Test Split","metadata":{}},{"cell_type":"code","source":"m_s = np.zeros(3)\nb_s =0\nlearning_rate=0.1 \ntrainX_s,testX_s,trainy_s,testy_s=train_test_split(X_scratch,y_scratch,test_size=0.2) #80 percent train and 20 percent test\nfor i in range(1000):\n    m, b = grad(trainX_s, trainy_s, m_s, b_s, learning_rate)\npredictions_s=sigmoid(testX_s @ m+b)\nfinal_predictions_s = (predictions_s >= 0.5).astype(int)\nprint(\"Accuracy Score of scratch: \")\nprint(accuracy_score(testy_s,final_predictions_s))","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}